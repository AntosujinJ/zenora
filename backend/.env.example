# Copy to .env and adjust as needed
MONGO_URI=mongodb://localhost:27017
DB_NAME=medmvp

# AI provider: "gemini" (cloud, free, deployable — recommended) or "ollama" (local)
AI_PROVIDER=gemini
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Use gemini-2.5-flash (free tier). gemini-2.0-flash may show 0 free quota.
GEMINI_MODEL=gemini-2.5-flash

# Ollama (only if AI_PROVIDER=ollama; local, needs GPU/CPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=220

# Clinic info (used by the AI receptionist + website)
CLINIC_NAME=Sunrise Medical Clinic
CLINIC_PHONE=+91 98765 43210
CLINIC_ADDRESS=12 Wellness Road, Kochi, Kerala
CLINIC_HOURS=Mon-Sat 9:00 AM - 6:00 PM

CORS_ORIGINS=http://localhost:5173

# Payments (Razorpay). Leave blank for DEMO mode (simulated, no real charge).
# Free test keys: https://dashboard.razorpay.com → Settings → API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CONSULTATION_FEE_INR=500

# Staff auth — IMPORTANT for production:
#  - Set a long random JWT_SECRET (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`)
#  - Change the default admin login below, then create real staff in the Team tab.
JWT_SECRET=change-me-to-a-long-random-string
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
# Legacy shared key (no longer used by the UI; safe to ignore)
STAFF_KEY=zenora-staff-2026

# ---------- Notifications ----------
# Leave blank to run in CONSOLE mode (messages print to the terminal instead of
# sending) so you can test the flow with zero setup. Fill these in to go live.
NOTIFY_EMAIL=true
NOTIFY_WHATSAPP=true

# Email via Gmail SMTP (free):
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Put your gmail + the 16-char app password below
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# WhatsApp via Meta Cloud API (free tier ~1000 conversations/month):
#   https://developers.facebook.com  ->  WhatsApp  ->  API Setup
#   NOTE: business-initiated reminders need an APPROVED message template.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
DEFAULT_COUNTRY_CODE=91

# Reminder timing: minutes before the appointment. "1440,120" = 24h and 2h.
REMINDER_OFFSETS_MINUTES=1440,120
SCHEDULER_INTERVAL_SECONDS=120
